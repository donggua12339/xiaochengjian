# ===========================================
# 小城笺后端环境变量模板
# 复制为 .env 并修改,生产环境通过 docker-compose 注入
# ===========================================

# 运行环境
NODE_ENV=development

# 服务端口
PORT=3000

# 数据库(PostgreSQL 16)
DATABASE_URL=postgresql://xiaochengjian:changeme@localhost:5432/xiaochengjian?schema=public

# Redis 7
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 密钥(生产环境必须改为随机 64 字符)
JWT_ACCESS_SECRET=changeme-access-secret-must-be-64-chars-or-more-in-production
JWT_REFRESH_SECRET=changeme-refresh-secret-must-be-64-chars-or-more-in-production

# JWT 过期时间
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 2FA TOTP 配置
TOTP_ISSUER=Xiaochengjian
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_STEP=30

# RSA 密钥对(SDK 通信加密,见 ADR 0020)
# 生成:openssl genrsa -out private.pem 2048
# 提取公钥:openssl rsa -in private.pem -pubout -out public.pem
RSA_PRIVATE_KEY_PATH=./keys/private.pem
RSA_PUBLIC_KEY_PATH=./keys/public.pem

# AES 会话缓存 TTL(秒),SDK 协商的 AES 密钥有效期
SDK_SESSION_TTL=3600

# 限流默认值(可被应用级配置覆盖,见 ADR 0022)
RATE_LIMIT_IP_PER_MINUTE=60
RATE_LIMIT_DEVICE_PER_MINUTE=30
RATE_LIMIT_FAIL_LOCK_THRESHOLD=5
RATE_LIMIT_FAIL_LOCK_TTL=3600

# 离线缓存默认 TTL(天,可被应用级配置覆盖,见 ADR 0017)
OFFLINE_CACHE_DEFAULT_DAYS=7
OFFLINE_CACHE_MAX_DAYS=30

# 卡密生成批量上限
CARD_KEY_BATCH_MAX=10000

# 日志级别:debug / info / warn / error
LOG_LEVEL=info

# CORS 允许的前端源(逗号分隔)
CORS_ORIGINS=http://localhost:5173

# 管理后台 URL(用于邮件链接等)
ADMIN_WEB_URL=http://localhost:5173
