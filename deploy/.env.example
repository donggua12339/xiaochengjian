# 小城笺 Docker Compose 环境变量模板
# 用法:cp .env.example .env && 修改所有 changeme 值

# ============= PostgreSQL =============
# 注:模板默认 xcj_admin,生产实际部署时改为强密码用户名(如 xcj_dba)
# 生产环境实际值见服务器 /opt/xiaochengjian/deploy/.env(权限 600)
POSTGRES_USER=xcj_admin
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=xiaochengjian

# ============= Redis =============
REDIS_PASSWORD=changeme_redis_password_here

# ============= JWT(必须 32+ 字符,生产环境必须改) =============
JWT_ACCESS_SECRET=please-change-this-to-random-32-char-string
JWT_REFRESH_SECRET=please-change-this-to-another-random-32-char-string

# ============= Grafana =============
GRAFANA_PASSWORD=changeme_grafana_admin

# ============= 前端 =============
CORS_ORIGINS=http://localhost,https://your-domain.com
ADMIN_WEB_URL=http://localhost

# ============= 告警(飞书 webhook,M3.3 配置) =============
FEISHU_WEBHOOK_URL=

# ============= OAuth(ADR 0074,可选,未配则 OAuth 接口拒绝) =============
# GitHub OAuth App:https://github.com/settings/developers
# Authorization callback URL:https://your-domain/v1/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# QQ 互联:https://connect.qq.com
# 回调地址:https://your-domain/v1/auth/oauth/qq/callback
QQ_APP_ID=
QQ_APP_KEY=

# ============= WM 发卡网对接(ADR 0075,可选) =============
# WM 发卡网 API(详见 ADR 0044/0051/0075)
# 未配则走手动兜底(管理员后台生成激活码 + 手动发货)
WM_API_BASE=
WM_API_KEY=
WM_MERCHANT_ID=
# Webhook 回调地址:https://your-domain/v1/webhooks/wm/order-paid
WM_WEBHOOK_SECRET=

# ============= 自有 APK 诊断(ADR 0077)=============
# 诊断临时目录根(容器内 /tmp/audit,按 taskId 隔离,权限 700)
AUDIT_TMP_ROOT=/tmp/audit
# apksigner 二进制路径(Dockerfile 装 build-tools 后为 /opt/android-sdk/build-tools/34.0.0/apksigner)
APKSIGNER_PATH=/opt/android-sdk/build-tools/34.0.0/apksigner
# 诊断报告保留时长(小时,默认 24)
AUDIT_REPORT_RETENTION_HOURS=24
# 诊断并发上限(每开发者,ADR 0077 §7 默认 1)
AUDIT_MAX_CONCURRENT_PER_DEV=1
# APK 大小上限(MB,ADR 0077 §7 默认 200)
AUDIT_MAX_APK_SIZE_MB=200
# 诊断超时(秒,ADR 0077 §7 默认 1800 = 30 分钟)
AUDIT_TIMEOUT_SECONDS=1800

# ============= 水印 AES-256 密钥(ADR 0030 §c,生产环境强制)=============
# 32 字节 hex(64 字符),用于 /v1/watermark/generate 加密水印
# 生成:openssl rand -hex 32
# 生产环境未配或长度非 64,backend 启动会 fail(见 configuration.ts validate)
WATERMARK_AES_KEY=

# ============= Integrity(方案 C 服务端 gate,ADR 0088 v2.1.1)=============
# token 签名密钥(HMAC-SHA256,生产必须 32+ 字符)
# 生成:openssl rand -hex 32
INTEGRITY_TOKEN_SECRET=
# RSA 私钥(PEM 格式,解密客户端用公钥加密的签名哈希)
# 生成:openssl genrsa -out integrity_private.pem 2048
# 填入方式:把 PEM 内容拼成单行(\n 换行转义),或用 ${VAR} 引用文件
# 简化:用 docker-compose volumes 挂载密钥文件,service 启动时读
INTEGRITY_RSA_PRIVATE_KEY=
