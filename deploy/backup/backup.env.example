# 小城笺备份脚本环境变量模板
# 用法:复制到 /etc/xcj-backup.env(权限 600,root only),填入实际值
# 详见 ADR 0072

# ============= 备份存储 =============
BACKUP_DIR=/opt/xcj-backups

# ============= PostgreSQL =============
PG_CONTAINER=xcj-postgres
# 注:实际 PG_USER 由 docker-compose 的 POSTGRES_USER 决定
# - handover.md / .env.example 写的是 xcj_admin(模板默认值,不准)
# - 生产环境实际是 xcj_dba(部署时改过,文档未同步)
# 部署时按服务器实际 .env 的 POSTGRES_USER 填
PG_USER=xcj_dba
PG_DB=xiaochengjian

# ============= backend(恢复时需停) =============
BACKEND_CONTAINER=xcj-backend
HEALTH_URL=http://localhost:8088/health

# ============= 加密 =============
# gpg 对称密钥文件路径(权限 600,root only)
# 内容:一行随机字符串(建议 32+ 字符)
KEY_FILE=/etc/xcj-backup.key

# ============= 源码目录(备份 schema + .env 用) =============
DEPLOY_DIR=/opt/xiaochengjian/deploy
BACKEND_DIR=/opt/xiaochengjian/backend
