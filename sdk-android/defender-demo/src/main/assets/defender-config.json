  "antiDebug": { "enabled": true, "onViolation": "none" },
  "antiFrida": { "enabled": true, "onViolation": "none" },
  "antiDump": { "enabled": true, "onViolation": "none" },
  "rootDetect": { "enabled": true, "onViolation": "none" },
